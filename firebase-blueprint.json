{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the EnvisionPaths platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "is_admin": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "created_at"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "An interview simulation session.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "job_title": { "type": "string" },
        "industry": { "type": "string" },
        "score": { "type": "integer" },
        "feedback": { "type": "string" },
        "status": { "type": "string", "enum": ["started", "completed"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "job_title", "industry", "status", "created_at"]
    },
    "SimulationMessage": {
      "title": "SimulationMessage",
      "description": "A message within an interview simulation.",
      "type": "object",
      "properties": {
        "simulation_id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["simulation_id", "role", "content", "created_at"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A practice session reminder.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "scheduled_at": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "title", "scheduled_at", "completed", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/simulations/{simulationId}": {
      "schema": "Simulation",
      "description": "Interview simulation sessions."
    },
    "/simulations/{simulationId}/messages/{messageId}": {
      "schema": "SimulationMessage",
      "description": "Messages within a simulation."
    },
    "/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "User reminders."
    }
  }
}
